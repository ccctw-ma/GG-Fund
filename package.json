{
  "name": "gg-fund",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "bun run backend/local.ts",
    "dev": "bun --bun concurrently -k \"bun run dev:api\" \"bun run dev:web\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "bun run typecheck && vite build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/fund-flow.spec.ts",
    "test:midscene": "zsh scripts/test-midscene.sh",
    "check": "bun run lint && bun run test && bun run coverage && bun run build && bun run test:e2e",
    "precommit:install": "git config core.hooksPath .githooks",
    "ci:test": "bash scripts/ci-test.sh",
    "deploy:cloudflare": "bash scripts/deploy-cloudflare.sh",
    "verify:cloudflare": "bash scripts/verify-cloudflare.sh",
    "start": "bun run backend/local.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@midscene/web": "latest",
    "@playwright/test": "latest",
    "@eslint/js": "latest",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "latest",
    "@vitest/browser": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "playwright": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
