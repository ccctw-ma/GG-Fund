{
  "name": "gg-fund",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "bun run typecheck && next build",
    "preview": "bunx --package @opennextjs/cloudflare opennextjs-cloudflare build && bunx --package @opennextjs/cloudflare opennextjs-cloudflare preview",
    "deploy:cloudflare": "bash scripts/deploy-cloudflare.sh",
    "verify:cloudflare": "bash scripts/verify-cloudflare.sh",
    "actions:list": "node scripts/github-actions.js list --repo ccctw-ma/GG-Fund --workflow cloudflare-deploy.yml --branch master --limit 5",
    "actions:watch": "node scripts/github-actions.js watch --repo ccctw-ma/GG-Fund --exit-status",
    "actions:view": "node scripts/github-actions.js view --repo ccctw-ma/GG-Fund --log-failed",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e/next-core.spec.ts tests/e2e/email-login.spec.ts tests/fund-flow.spec.ts",
    "test:midscene": "zsh scripts/test-midscene.sh",
    "check": "bun run lint && bun run test && bun run coverage && bun run build && bun run test:e2e",
    "precommit:install": "git config core.hooksPath .githooks",
    "ci:test": "bash scripts/ci-test.sh",
    "start": "bun run preview"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "latest",
    "next": "^16.2.6",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tesseract.js": "^7.0.0",
    "typescript": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@midscene/web": "latest",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "latest",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "playwright": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wrangler": "^4.95.0"
  },
  "optionalDependencies": {
    "@ast-grep/napi-linux-x64-gnu": "0.40.5",
    "@cloudflare/workerd-linux-64": "1.20260526.1",
    "@esbuild/linux-x64": "0.27.3",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
